# backend/.env

# Параметры базы данных
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=SbkH2yJrrUZ5ns9
DB_NAME=myapp

# JWT настройки
SECRET_KEY=dev_secret_key_change_in_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Приложение
ENVIRONMENT=development
FRONTEND_URL=http://127.0.0.1:5173
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# SMTP-рассылка. Если SMTP_HOST пустой, письма только логируются.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@togu.example
SMTP_USE_TLS=true
